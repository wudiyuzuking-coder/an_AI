.container {
  padding: 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.title-bar {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #eee;
}

.form-group {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

textarea {
  width: 100%;
  min-height: 300rpx;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.submit-btn {
  background-color: #4CAF50;
  color: #fff;
  font-size: 32rpx;
  border-radius: 50rpx;
  padding: 20rpx 0;
  margin-bottom: 40rpx;
}

.submit-btn[disabled] {
  background-color: #ccc;
  color: #999;
}

.result-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.result-text {
  font-size: 30rpx;
  color: #333;
  text-align: center;
  margin: 20rpx 0;
}

.badge {
  background-color: #e8f5e9;
  color: #4CAF50;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  margin-top: 10rpx;
}
